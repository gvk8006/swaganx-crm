# MT5 Bridge Configuration
# =========================

# Server
PORT=8443
HOST=0.0.0.0

# Authentication (must match CRM .env)
BRIDGE_API_KEY=your-secret-api-key-here

# MT5 Manager API
MT5_SERVER_ADDRESS=127.0.0.1
MT5_MANAGER_LOGIN=1
MT5_MANAGER_PASSWORD=manager_password_here
MT5_DATA_PATH=C:/MT5/Data

# MT5 DLL Path
MT5_DLL_PATH=C:/MT5/ManagerAPI.dll

# Security
ALLOWED_ORIGINS=https://swaganx.com,http://localhost:3000
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/bridge.log

# WebSocket
WS_PING_INTERVAL=30000
